APP_NAME=AssocMAP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database: PostgreSQL ──────────────────────────────────────
# Change DB_DATABASE to your actual PostgreSQL database name.
# Change DB_USERNAME / DB_PASSWORD to your PostgreSQL credentials.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=assocmap
DB_USERNAME=postgres
DB_PASSWORD=

# ── Session: uses the database (sessions table) ───────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ─────────────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Mail ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@bfar.gov.ph"
MAIL_FROM_NAME="AssocMAP"

# ── Vite ──────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
